# =============================================================================
# AQL NODE — Environment Variables
# Copy nilai-nilai ini ke Railway → Service → Variables
# JANGAN commit file .env yang sudah diisi ke Git
# =============================================================================

# ── Polymarket ────────────────────────────────────────────────────────────────
# Private key wallet Polygon kamu (untuk signing CLOB order)
POLY_PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY_HERE

# ── Discord — 4 Webhook Terpisah ──────────────────────────────────────────────
# Cara buat: Discord Server → Server Settings → Integrations → Webhooks → New
#
# Channel #📊-aql-terminal (startup heartbeat + daily PnL)
TERMINAL_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Channel #☁-weather-data (Triple-Lock consensus update)
WEATHER_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Channel #📈-aql-trades (eksekusi trade)
TRADE_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Channel #🚨-alerts (error + circuit breaker)
ALERTS_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── Runtime ───────────────────────────────────────────────────────────────────
# Modal awal dalam USD
BANKROLL_USD=200.0

# Verbositas log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Railway inject PORT otomatis — jangan diset manual di sini
# PORT=8080
