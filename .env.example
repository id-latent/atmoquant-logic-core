# ==============================================================================
# AQL NODE — Environment Variables Template
# ==============================================================================
# CARA PAKAI:
#   Local  : Copy file ini ke .env lalu isi nilainya
#   Railway: Set semua variabel ini di Railway → Service → Variables
#
# ⚠️  JANGAN pernah commit file .env yang sudah diisi ke Git
# ⚠️  File ini (.env.example) aman untuk di-commit — hanya template
# ==============================================================================


# ── Polymarket ─────────────────────────────────────────────────────────────────
# Private key wallet Polygon kamu untuk signing CLOB orders (EIP-712)
# Format: 0x diikuti 64 karakter hex
# Cara dapat: Export dari MetaMask → Account Details → Export Private Key
POLY_PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY_HERE


# ── Discord Webhooks — 4 Channel Terpisah ─────────────────────────────────────
# Cara buat webhook:
#   Discord Server → Server Settings → Integrations → Webhooks → New Webhook
#   → Pilih channel → Copy Webhook URL
#
# Channel 1: #📊-aql-terminal (startup + heartbeat + daily PnL + weekly report)
TERMINAL_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Channel 2: #☁-weather-data (consensus update + model disagreement)
WEATHER_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Channel 3: #📈-aql-trades (trade executed + big edge + exit SL/TP)
TRADE_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Channel 4: #🚨-aql-alerts (error + circuit breaker + warnings)
ALERTS_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN


# ── Bankroll ───────────────────────────────────────────────────────────────────
# Modal awal dalam USD
# Minimum aman: $50 | Halt otomatis jika di bawah: $15
BANKROLL_USD=200.0


# ── Logging ────────────────────────────────────────────────────────────────────
# Verbositas log: DEBUG | INFO | WARNING | ERROR
# Gunakan INFO untuk production, DEBUG untuk troubleshooting
LOG_LEVEL=INFO


# ── Railway ────────────────────────────────────────────────────────────────────
# PORT diinjek otomatis oleh Railway — JANGAN diset manual
# PORT=8080
